	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"const moment = require('moment');",
					"",
					"const CONFIG = {",
					"    headersComunes: {",
					"        'Content-Type': 'application/json',",
					"        'X-Request-Usuario-Aplicativo': '46099060',",
					"        'X-Request-Usuario-Red': 'oruizb',",
					"        'X-Request-Ip': '172.34.12.71',",
					"        'X-Request-Pc': 'pc-oruizb',",
					"        'X-Request-Mac': 'aa-bb-cc-dd-ee-ff'",
					"    }",
					"};",
					"",
					"const getVar = (key) => pm.collectionVariables.get(key);",
					"const setVar = (key, value) => pm.collectionVariables.set(key, value);",
					"const buildUrl = (endpoint) => `${getVar('servidor')}/${getVar('contexto')}/${getVar(endpoint)}`;",
					"",
					"// 1. OBTENER OPERACIÓN ACTUAL",
					"const urlString = typeof request.url === 'string' ? request.url : request.url.toString();",
					"const operacion = urlString.split('?')[0].split('servicio-prueba-api')[1];",
					"const rutasIgnoradas = ['/healthcheck', '/api/authenticate', '/seguridad/refresh'];",
					"",
					"if (!rutasIgnoradas.includes(operacion)) {",
					"    const vars = pm.collectionVariables.toObject();",
					"    const hayLoNecesario = _.has(vars, 'jwtOpciones') || _.has(vars, 'refreshToken') || _.has(vars, 'expiredToken');",
					"    const ahora = moment().valueOf();",
					"    const refreshTokenVal = parseInt(getVar('refreshToken')) || 0;",
					"    const expiredTokenVal = parseInt(getVar('expiredToken')) || 0;",
					"",
					"    if (!hayLoNecesario || ahora >= refreshTokenVal) {",
					"        console.log('--- [PASO 0] Token inválido o expirado. Iniciando flujo síncrono estricto... ---');",
					"        ejecutarAuthenticate();",
					"    } else if (ahora > expiredTokenVal && ahora < refreshTokenVal) {",
					"        console.log('--- [PASO 0] Token en ventana de refresh. Iniciando actualización... ---');",
					"        ejecutarRefresh();",
					"    } else {",
					"        console.log('--- [PASO 0] Token aún válido. No se requieren peticiones previas. ---');",
					"    }",
					"}",
					"",
					"// 2. FLUJO COMPLETO EN CADENA (CALLBACKS CONTROLADOS)",
					"function ejecutarAuthenticate() {",
					"    console.log(' Lanzando /urlAuthenticate...');",
					"    pm.sendRequest({",
					"        url: buildUrl('urlAuthenticate'),",
					"        method: 'POST',",
					"        header: {",
					"            'Content-Type': 'application/json',",
					"            'username': getVar('usuario'),",
					"            'password': getVar('clave'),",
					"            'codigoCliente': getVar('cliente'),",
					"            'codigoRol': getVar('rol')",
					"        },",
					"        body: {}",
					"    }, function (err, resAuth) {",
					"        if (err || !resAuth || resAuth.code !== 200 || !resAuth.json()) {",
					"            console.error('❌ Error crítico en /urlAuthenticate');",
					"            setVar('jwtAuthenticate', null);",
					"            return;",
					"        }",
					"",
					"        const authData = resAuth.json();",
					"        const tokenAuth = authData.token;",
					"        ",
					"        setVar('jwtAuthenticate', tokenAuth);",
					"        setVar('texps', parseInt(authData.exps) || 0);",
					"        setVar('trefs', parseInt(authData.refs) || 0);",
					"        console.log('✅ jwtAuthenticate guardado.');",
					"",
					"        // Siguiente eslabón de la cadena",
					"        ejecutarLogin(tokenAuth);",
					"    });",
					"}",
					"",
					"function ejecutarLogin(tokenAuth) {",
					"    console.log(' Lanzando /urlLogin...');",
					"    pm.sendRequest({",
					"        url: buildUrl('urlLogin'),",
					"        method: 'POST',",
					"        header: { ...CONFIG.headersComunes, 'Authorization': 'Bearer ' + tokenAuth },",
					"        body: {",
					"            mode: 'raw',",
					"            raw: JSON.stringify({",
					"                usuario: getVar('userlogin'),",
					"                clave: getVar('passlogin'),",
					"                aplicaCaptcha: \"N\",",
					"                tokenCaptcha: \"\"",
					"            })",
					"        }",
					"    }, function (err, resLogin) {",
					"        if (err || !resLogin || resLogin.code !== 200 || !resLogin.json() || resLogin.json().codigo !== '0000') {",
					"            console.error('❌ Error crítico en /urlLogin');",
					"            return;",
					"        }",
					"",
					"        const tokenLogin = resLogin.json().data.token;",
					"        const perfil = resLogin.json().data.perfiles[0].idPerfil",
					"        setVar('jwtLogin', tokenLogin);",
					"        console.log('✅ jwtLogin guardado.');",
					"",
					"        // Siguiente eslabón de la cadena",
					"        ejecutarOpciones(tokenLogin,perfil);",
					"    });",
					"}",
					"",
					"function ejecutarOpciones(tokenLogin,perfil) {",
					"    console.log(' Lanzando /urlOpciones...');",
					"    pm.sendRequest({",
					"        url: buildUrl('urlOpciones'),",
					"        method: 'POST',",
					"        header: { ...CONFIG.headersComunes, 'Authorization': 'Bearer ' + tokenLogin },",
					"        body: {",
					"            mode: 'raw',",
					"            raw: JSON.stringify({ usuario: getVar('userlogin'), idPerfil: perfil })",
					"        }",
					"    }, function (err, resOpciones) {",
					"        if (!err && resOpciones && resOpciones.code === 200 && resOpciones.json() && resOpciones.json().codigo === '0000') {",
					"            const tokenFinal = resOpciones.json().data.token; ",
					"            const vexp = parseInt(getVar('texps')) || 0;",
					"            const vref = vexp + (parseInt(getVar('trefs')) || 0);",
					"            ",
					"            setVar('jwtOpciones', tokenFinal);",
					"            setVar('expiredToken', moment().add(vexp, 's').valueOf());",
					"            setVar('refreshToken', moment().add(vref, 's').valueOf());",
					"            console.log('🎉 Flujo completo exitoso. Petición principal liberada.');",
					"        } else {",
					"            setVar('jwtOpciones', null);",
					"            setVar('expiredToken', 0);",
					"            setVar('refreshToken', 0);",
					"            console.warn('⚠ El flujo falló en el paso de Opciones. Se resetearon los tokens.');",
					"        }",
					"    });",
					"}",
					"",
					"function ejecutarRefresh() {",
					"    const jwtOpciones = getVar('jwtOpciones');",
					"    pm.sendRequest({",
					"        url: buildUrl('urlRefresh') + '?token=' + jwtOpciones,",
					"        method: 'GET',",
					"        header: { ...CONFIG.headersComunes, 'Authorization': 'Bearer ' + jwtOpciones },",
					"        body: {}",
					"    }, function (err, resRefresh) {",
					"        if (!err && resRefresh && resRefresh.code === 200 && resRefresh.json() && resRefresh.json().codigo === '0000') {",
					"            const tokenFinal = resRefresh.json().data.token;",
					"            const vexp = parseInt(getVar('texps')) || 0;",
					"            const vref = vexp + (parseInt(getVar('trefs')) || 0);",
					"            ",
					"            setVar('jwtOpciones', tokenFinal);",
					"            setVar('expiredToken', moment().add(vexp, 's').valueOf());",
					"            setVar('refreshToken', moment().add(vref, 's').valueOf());",
					"            console.log('🔄 Token refrescado con éxito.');",
					"        } else {",
					"            setVar('expiredToken', 0);",
					"            setVar('refreshToken', 0);",
					"            console.error('❌ Error al intentar refrescar el token.');",
					"        }",
					"    });",
					"}"
				]
			}
		},
